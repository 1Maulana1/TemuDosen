{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "preDeployCommand": "python manage.py migrate && python manage.py seed_admin",
    "startCommand": "sh start.sh",
    "restartPolicyType": "ON_FAILURE"
  }
}
