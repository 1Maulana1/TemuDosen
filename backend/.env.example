SECRET_KEY=your-secret-key-here-replace-in-production
DATABASE_URL=sqlite:///db.sqlite3
MEDIA_ROOT=storage
DEBUG=True

# --- Phase 6: STT + AI Summarization (opsional; default semua OFF) ---
# Aktifkan pipeline STT->LLM. False = semua sesi selalu jatuh ke jalur manual (STT-07).
STT_LLM_ENABLED=False

# Redis broker untuk Celery (butuh Redis jalan; lihat docker-compose.dev.yml).
CELERY_BROKER_URL=redis://localhost:6379/0

# --- STT (Speech-to-Text) ---
# 'groq' (API, ringan) atau 'local' (faster-whisper, butuh RAM ~1-2GB).
# 'groq' tanpa GROQ_API_KEY otomatis jatuh ke 'local' (lihat services/stt.py).
STT_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_TIMEOUT=300
# Hanya dipakai bila STT_PROVIDER=local.
STT_MODEL_SIZE=small
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=id
STT_MODEL_DOWNLOAD_ROOT=storage/whisper_models

# --- LLM Summarization ---
# 'groq' (llama-3.3-70b, satu key sama dengan STT) atau 'anthropic' (claude, berbayar).
# 'groq' tanpa GROQ_API_KEY jatuh ke 'anthropic' bila key-nya ada (services/summarizer.py).
LLM_PROVIDER=groq
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_LLM_TIMEOUT=120
# Opsional: hanya dipakai bila LLM_PROVIDER=anthropic, atau sebagai fallback saat GROQ_API_KEY kosong.
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_BATCH_TIMEOUT_MINUTES=180
LLM_INPUT_RATE_USD_PER_MTOK=0.50
LLM_OUTPUT_RATE_USD_PER_MTOK=2.50
